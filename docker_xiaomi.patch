diff --git a/include/linux/sched.h b/include/linux/sched.h
--- a/include/linux/sched.h	2026-03-17 04:30:12.000000000 +0800
+++ b/include/linux/sched.h	2026-04-05 01:40:01.333482513 +0800
@@ -1190,11 +1190,6 @@
 	char				comm[TASK_COMM_LEN];
 
 	struct nameidata		*nameidata;
-
-#ifdef CONFIG_SYSVIPC
-	struct sysv_sem			sysvsem;
-	struct sysv_shm			sysvshm;
-#endif
 #ifdef CONFIG_DETECT_HUNG_TASK
 	unsigned long			last_switch_count;
 	unsigned long			last_switch_time;
@@ -1650,9 +1645,25 @@
 	 */
 	struct callback_head		l1d_flush_kill;
 #endif
-	ANDROID_KABI_RESERVE(1);
-	ANDROID_KABI_RESERVE(2);
-	ANDROID_KABI_RESERVE(3);
+	/*
+	 * Reuse tail KABI reserves so CONFIG_SYSVIPC n->y does not perturb
+	 * task_struct middle layout:
+	 * - sysvsem: 8B when CONFIG_SYSVIPC=y (fits reserve1, 8B)
+	 * - sysvshm: 16B when CONFIG_SYSVIPC=y (fits reserve2+3, 16B)
+	 */
+union {
+    struct {
+        ANDROID_KABI_RESERVE(1);
+        ANDROID_KABI_RESERVE(2);
+        ANDROID_KABI_RESERVE(3);
+    };
+#ifdef CONFIG_SYSVIPC
+    struct {
+        struct sysv_sem sysvsem;   /* 8 字节（一个指针） */
+        struct sysv_shm sysvshm;   /* 16 字节（两个指针） */
+    };
+#endif
+};
 	ANDROID_KABI_RESERVE(4);
 	ANDROID_KABI_RESERVE(5);
 	ANDROID_KABI_RESERVE(6);
